---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { brand, hero, productIntro, occasions, finishes, availability, storyTeaser } from '../data/config';
---
<BaseLayout title={`${brand.name} — ${brand.tagline}`}>
  <Nav slot="nav" currentPath="/" />

  <!-- ═══ HERO ═══ -->
  <section class="hero" aria-label="Introduction">
    <div class="hero__inner container">
      <div class="hero__brand">
        <img src="/logo.png" alt="Cakish" class="hero__logo" />
      </div>
      <div class="hero__divider"></div>
      <div class="hero__content">
        <h1 class="t-display hero__headline">{hero.headline}</h1>
        <p class="t-subtitle hero__subtitle">{hero.subtitle}</p>
        <div class="hero__cta">
          <a href="/order" class="btn btn--primary">Order Now</a>
        </div>
      </div>
    </div>
    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-line"></span>
    </div>
  </section>

  <!-- ═══ PRODUCT INTRO ═══ -->
  <section class="section section--lg" aria-label="Product introduction">
    <div class="container--wide">
      <div class="intro reveal">
        <span class="t-eyebrow">{productIntro.eyebrow}</span>
        <hr class="gold-rule" style="margin: 1.25rem 0 2rem;" />
        <div class="intro__grid">
          <div class="intro__text">
            <h2 class="t-headline">{productIntro.heading}</h2>
            <p class="t-body-lg" style="margin-top: 1.5rem; max-width: 520px;">
              {productIntro.body}
            </p>
          </div>
          <div class="intro__visual reveal reveal-delay-2">
            <div class="editorial-frame editorial-frame--hero">
              <img src="/images/pavlova-detail.jpg" alt="The Cakish Modern Pavlova — meringue, cream, and seasonal fruit" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MADE FOR ═══ -->
  <section class="section occasions-section" aria-label="Made for">
    <div class="container--wide">
      <div class="occasions reveal">
        <h2 class="t-headline occasions__heading">{occasions.heading}</h2>
        <div class="occasions__list">
          {occasions.items.map((item, i) => (
            <div class:list={['occasions__item', 'reveal', `reveal-delay-${i % 4 + 1}`]}>
              <h3 class="t-title">{item.name}</h3>
              <p class="t-body">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FINISHES ═══ -->
  <section class="section section--lg" aria-label="Finishes">
    <div class="container--wide">
      <div class="finishes reveal">
        <span class="t-eyebrow">Two Finishes</span>
        <hr class="gold-rule" style="margin: 1.25rem 0 2rem;" />
        <div class="finishes__grid">
          {finishes.map((finish, i) => (
            <div class:list={['finishes__card', 'reveal', `reveal-delay-${i + 1}`]}>
              <div class="editorial-frame editorial-frame--portrait">
                <img
                  src={i === 0 ? '/images/pavlova-floral.jpg' : '/images/pavlova-sliced.jpg'}
                  alt={finish.name}
                  loading="lazy"
                />
              </div>
              <div class="finishes__card-content">
                <h3 class="t-title" style="margin-top: 1.5rem;">{finish.name}</h3>
                <p class="t-body" style="margin-top: 0.75rem;">{finish.description}</p>
                {finish.surcharge > 0 && (
                  <span class="t-label" style="margin-top: 1rem; display: inline-block; color: var(--soft-gold);">
                    +€{finish.surcharge}
                  </span>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ AVAILABILITY ═══ -->
  <section class="section availability-section" aria-label="Availability">
    <div class="container--narrow" style="text-align: center;">
      <div class="reveal">
        <hr class="gold-rule gold-rule--center" />
        <h2 class="t-headline" style="margin-top: 2rem;">{availability.heading}</h2>
        <p class="t-body-lg" style="margin-top: 1.25rem;">{availability.body}</p>
        <a href="/order" class="btn btn--primary" style="margin-top: 2rem;">{availability.cta}</a>
      </div>
    </div>
  </section>

  <!-- ═══ STORY TEASER ═══ -->
  <section class="section section--lg" aria-label="Our story">
    <div class="container--wide">
      <div class="story-teaser reveal">
        <div class="story-teaser__content">
          <span class="t-eyebrow">{storyTeaser.eyebrow}</span>
          <hr class="gold-rule" style="margin: 1.25rem 0 2rem;" />
          <h2 class="t-headline">{storyTeaser.heading}</h2>
          <p class="t-body-lg" style="margin-top: 1.25rem; max-width: 440px;">
            {storyTeaser.body}
          </p>
          <a href="/story" class="btn btn--ghost" style="margin-top: 2rem;">{storyTeaser.cta} →</a>
        </div>
        <div class="story-teaser__visual reveal reveal-delay-2">
          <div class="editorial-frame editorial-frame--landscape">
            <img src="/images/story-landscape.jpg" alt="Elegant table setting with a Cakish pavlova centrepiece" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(198, 167, 105, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 30%, rgba(216, 167, 167, 0.05) 0%, transparent 50%),
      var(--ivory);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    padding: 6rem 0;
  }

  .hero__brand {
    display: flex;
    justify-content: flex-end;
    padding-right: clamp(1rem, 3vw, 3rem);
  }

  .hero__logo {
    width: clamp(140px, 18vw, 220px);
    height: auto;
    opacity: 0;
    animation: heroFadeIn 1.2s var(--ease-out) 0.2s forwards;
  }

  .hero__divider {
    width: 1px;
    height: clamp(180px, 30vh, 300px);
    background: linear-gradient(180deg, transparent, var(--soft-gold), transparent);
    opacity: 0;
    animation: heroFadeIn 1s var(--ease-out) 0.5s forwards;
  }

  .hero__content {
    padding-left: clamp(1rem, 3vw, 3rem);
    max-width: 520px;
    opacity: 0;
    animation: heroSlideIn 1s var(--ease-out) 0.4s forwards;
  }

  .hero__headline { margin-bottom: 1rem; }

  .hero__cta { margin-top: 2.5rem; }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    animation: heroFadeIn 1s var(--ease-out) 1.2s forwards;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(180deg, var(--soft-gold), transparent);
    animation: scrollPulse 2s var(--ease-in-out) infinite;
  }

  @keyframes heroFadeIn {
    to { opacity: 1; }
  }
  @keyframes heroSlideIn {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.15); }
  }

  /* ── Intro ── */
  .intro__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    margin-top: 0.5rem;
  }

  /* ── Occasions ── */
  .occasions-section {
    background: var(--soft-cream);
  }
  .occasions__heading {
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }
  .occasions__list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .occasions__item {
    padding: var(--space-md) 0;
    border-top: 1px solid var(--line);
  }
  .occasions__item h3 {
    margin-bottom: 0.5rem;
  }

  /* ── Finishes ── */
  .finishes__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
  }
  .finishes__card:nth-child(2) {
    margin-top: clamp(2rem, 5vw, 5rem);
  }

  /* ── Story teaser ── */
  .story-teaser {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
      padding: 7rem 0 3rem;
    }
    .hero__brand {
      justify-content: center;
      padding-right: 0;
    }
    .hero__divider {
      width: 48px;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--soft-gold), transparent);
      margin: 0 auto;
    }
    .hero__content {
      padding-left: 0;
      max-width: 400px;
      margin: 0 auto;
    }
    .hero__cta { margin-top: 2rem; }

    .intro__grid { grid-template-columns: 1fr; }
    .finishes__grid { grid-template-columns: 1fr; }
    .finishes__card:nth-child(2) { margin-top: 0; }
    .story-teaser { grid-template-columns: 1fr; }
    .occasions__list { grid-template-columns: 1fr; }
  }
</style>
